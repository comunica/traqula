SELECT ?o ?p ?s ?Z1 ?Z2 ?Z3 WHERE {
  ?s ?p ?o .
  ?g_75 <http://www.w3.org/1999/02/22-rdf-syntax-ns#reifies> <<( ?s ?p ?o )>> .
  ?g_75 <http://example.com/ns#r1> ?Z1 .
  ?g_76 <http://www.w3.org/1999/02/22-rdf-syntax-ns#reifies> <<( ?s ?p ?o )>> .
  ?g_76 <http://example.com/ns#r2> ?Z2 .
  ?g_77 <http://www.w3.org/1999/02/22-rdf-syntax-ns#reifies> <<( ?s ?p ?o )>> .
  ?g_77 <http://example.com/ns#r3> ?Z3 .
}