INSERT {
  GRAPH <http://example/addresses> {
    ?person <http://xmlns.com/foaf/0.1/name> ?name .
    ?person <http://xmlns.com/foaf/0.1/mbox> ?email .
  }
}
WHERE {
  GRAPH <http://example/people> {
    ?person <http://xmlns.com/foaf/0.1/name> ?name .
    OPTIONAL {
      ?person <http://xmlns.com/foaf/0.1/mbox> ?email .
    }
  }
}