INSERT {
  GRAPH <http://example/bookStore2> {
    ?book ?p ?v .
  }
}
WHERE {
  GRAPH <http://example/bookStore> {
    ?book <http://purl.org/dc/elements/1.1/date> ?date .
    ?book ?p ?v .
    FILTER ( ( ?date < "2000-01-01T00:00:00-02:00"^^<http://www.w3.org/2001/XMLSchema#dateTime> ) )
  }
}
;
DELETE {
  GRAPH <http://example/bookStore> {
    ?book ?p ?v .
  }
}
WHERE {
  GRAPH <http://example/bookStore> {
    ?book <http://purl.org/dc/elements/1.1/date> ?date .
    ?book <http://purl.org/dc/elements/1.1/type> <http://purl.org/dc/dcmitype/PhysicalObject> .
    ?book ?p ?v .
    FILTER ( ( ?date < "2000-01-01T00:00:00-02:00"^^<http://www.w3.org/2001/XMLSchema#dateTime> ) )
  }
}