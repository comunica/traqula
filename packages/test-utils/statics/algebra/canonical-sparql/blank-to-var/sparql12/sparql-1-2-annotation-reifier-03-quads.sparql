SELECT ?q ?z WHERE {
  ?g_0 <http://www.w3.org/1999/02/22-rdf-syntax-ns#reifies> <<( <http://example.com/ns#a> <http://example.com/ns#b> <http://example.com/ns#c> )>> .
  <http://example.com/ns#s> <http://example.com/ns#p> ?g_0 .
  ?e_bnode <http://www.w3.org/1999/02/22-rdf-syntax-ns#reifies> <<( <http://example.com/ns#s> <http://example.com/ns#p> ?g_0 )>> .
  ?e_bnode ?q ?z .
}