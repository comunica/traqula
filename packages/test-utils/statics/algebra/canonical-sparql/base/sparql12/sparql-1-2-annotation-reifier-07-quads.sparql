SELECT ?o ?p ?s WHERE {
  ?s ?p ?o .
  <http://example.com/ns#iri> <http://www.w3.org/1999/02/22-rdf-syntax-ns#reifies> <<( ?s ?p ?o )>> .
  _:g_128 (<http://example.com/ns#p1>|<http://example.com/ns#p2>) "ABC"^^<http://www.w3.org/2001/XMLSchema#string> .
  <http://example.com/ns#iri> <http://example.com/ns#r> _:g_128 .
}