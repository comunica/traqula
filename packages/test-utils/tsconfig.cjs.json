{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "declaration": false,
    "outDir": "dist/cjs",
    "skipLibCheck": true,
    "isolatedDeclarations": false
  },
  "include": [
    "lib/**/*.ts"
  ],
  "exclude": ["dist/**", "lib/index.ts"]

}
